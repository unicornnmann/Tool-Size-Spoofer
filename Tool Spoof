SubmitGeneration.MouseButton1Click:Connect(function()
    if isGenerating then
        return
    end
    
    local DotSequence = {"", ".", "..", "...", "...", "..", ".", ""}
    
    isGenerating = true
    SubmitGeneration.Text = "Generating"
    
    ToolGenerate:FireServer(tostring(InputBox.Text), Vector3.new(tonumber(InputBoxX.Text), tonumber(InputBoxY.Text), tonumber(InputBoxZ.Text)))
    
    task.spawn(function()
        local index = 1
        while isGenerating do
            SubmitGeneration.Text = "Generating" .. DotSequence[index]
            index = index + 1
            if index > #DotSequence then
                index = 1
            end
            task.wait(0.15)
        end
        
        if SubmitGeneration.Text ~= "Submit" then
            SubmitGeneration.Text = "Submit"
        end
    end)
end)

ToolGenerateDone.OnClientEvent:Connect(function()
    isGenerating = false
    SubmitGeneration.Text = "Submit"
end)

Main.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        DragSettings.Toggle = true
        DragSettings.Start = input.Position
        DragSettings.InitialPosition = Main.Position
        
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                DragSettings.Toggle = false
            end
        end)
    end
end)

InputService.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        if DragSettings.Toggle then
            UpdateDrag(input, Main)
        end
    end
end)

Player.Chatted:Connect(function(Message)
    if Message:lower() == "tg" then
        isUIVisible = not isUIVisible
        
        local targetTransparency = isUIVisible and 0 or 1
        local targetStrokeTransparency = isUIVisible and 0 or 1
        
        if isUIVisible then
            CustomToolSpoofer.Enabled = true
            
            TweenService:Create(Main, TweenInfo.new(0.4, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {BackgroundTransparency = 0.5}):Play()
            
            TweenService:Create(MainStroke, TweenInfo.new(0.4, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {Transparency = 0}):Play()
            
            local textElements = {Title, InputBox, InputBoxX, InputBoxY, InputBoxZ, SubmitGeneration}

            for _, elem in ipairs(textElements) do
                TweenService:Create(elem, TweenInfo.new(0.4, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {BackgroundTransparency = elem:IsA("TextButton") or elem:IsA("TextBox") and 0 or 1, TextTransparency = 0, TextStrokeTransparency = 0}):Play()
            end
        else
            TweenService:Create(Main, TweenInfo.new(0.4, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {BackgroundTransparency = 1}):Play()
            
            TweenService:Create(MainStroke, TweenInfo.new(0.4, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {Transparency = 1}):Play()
            
            local textElements = {Title, InputBox, InputBoxX, InputBoxY, InputBoxZ, SubmitGeneration}
            
            for _, elem in ipairs(textElements) do
                TweenService:Create(elem, TweenInfo.new(0.4, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {BackgroundTransparency = 1, TextTransparency = 1, TextStrokeTransparency = 1}):Play()
            end
            
            task.delay(TweenInfo.new(0.4, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut).Time, function()
                if not isUIVisible then
                    CustomToolSpoofer.Enabled = false
                end
            end)
        end
    end
end)

